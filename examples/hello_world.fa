# Basic Hello World.
# Run with:
#   just asm-exec '(mem_size: "16mb", rom: "target/examples/hello_world.fo", devices: [raw_io(port: 0)])'
# The raw_io device outputs raw bytes directly as ASCII characters.
# An equivalent c program would be:
#   #include <stdio.h>
#   int main() {
#     char *msg = "Hello, world!\n";
#     while (*msg) {
#       char c = *msg;
#       putchar(c);
#       msg++;
#     }
#     return 0;
#   }

.rodata
  msg: db "Hello, world!\n", 0

.code
main:
  MOV rw1, msg            # rw1 = address of msg
  .loop:
    LOAD rb2, rw1         # rb2 = byte at rw1
    CMP rb2, 0            # check for null terminator
    JZ .done              # if zero, we're done
    ADD rw1, 1            # rw1++ (move to next byte)
    OUT 0, rb2            # write byte to port 0
    JMP .loop             # repeat
  .done:
  HALT