# Register and stack test
# Run with:
#   just asm-exec '(mem_size: "16mb", rom: "target/examples/reg.fo", devices: [])'
.code
main:
MOV rw0, 42
PUSH rw0
MOV rw0, 0
POP rw1
MOV rw2, rw1

# 32-bit immediate
MOV rw3, 0x12345678

# Byte-view access: write low byte only, upper bits are preserved
MOV rw4, 0xAABBCCDD
MOV rb4, 0xFF

# Byte-lane stack round-trip
PUSH rb4
POP rb5

HALT
