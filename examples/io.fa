# I/O port example
#
# Run with:
#   just asm-exec '(mem_size: "16mb", rom: "target/examples/io.fo", devices: [(type: "hex_io", port: 0, input: "stdin", output: "stdout")])'
#
# The exact host-side rendering depends on the device bound to port 0.

.code
main:

# Byte-view write: sends an 8-bit value to the port
MOV  rb0, 0x41
OUT  0, rb0

# Word write: sends the full 32-bit value to the port
MOV  rw1, 0x00000042
OUT  0, rw1

HALT
