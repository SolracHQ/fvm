# I/O port example
#
# Writes values to port 0 (hexprint device, auto-registered by the CLI).
# Run with: fvm run-asm -s examples/io.fa -m0:::hex
#
# Expected output on stdout:
#   0x41
#   0x00
#   0x42

# Byte-lane write: sends exactly one byte to the port
MOV  r0l, 0x41
OUT  0, r0l        # prints: 0x41

# Full-register write: sends two bytes, high byte first (big-endian)
MOV  r1, 0x0042
OUT  0, r1         # prints: 0x00
                   #         0x42

HALT
