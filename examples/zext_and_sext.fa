# Zero/sign extension across byte, halfword, and word views.
# Run with:
#   just asm-exec '(mem_size: "16mb", rom: "target/examples/zext_and_sext.fo", devices: [])'

.code
main:

# byte -> halfword
MOV  rb0, 0xFF
ZEXT rh1, rb0

# byte -> word
MOV  rb2, 0x80
ZEXT rw3, rb2

# halfword -> word
MOV  rh4, 0x8001
ZEXT rw5, rh4

# signed byte -> halfword
MOV  rb6, 0x80
SEXT rh7, rb6

# signed byte -> word
MOV  rb8, 0xFF
SEXT rw9, rb8

# signed halfword -> word
MOV  rh10, 0x8001
SEXT rw11, rh10

HALT