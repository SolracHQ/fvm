# Arithmetic and bitwise operations
#
# Demonstrates ADD, SUB, AND, OR, XOR, NOT, and CMP.
# Run with:
#   just asm-exec '{"mem_size":16777216,"rom":"target/examples/arithmetic.fo","devices":[]}'

.code
main:

# Integer arithmetic
MOV  rw0, 10
MOV  rw1, 3
ADD  rw0, rw1      # rw0 = 13

MOV  rw2, 100
MOV  rw3, 37
SUB  rw2, rw3      # rw2 = 63

# Bitwise operations
MOV  rw4, 0xFF00FF00
MOV  rw5, 0x0F0F00FF
AND  rw4, rw5      # rw4 = 0x0F000000
OR   rw4, rw5
XOR  rw4, rw5      # rw4 == 0 after XOR with itself

MOV  rw6, 0x000000FF
NOT  rw6

# Byte-view arithmetic
MOV  rb7, 0x05
MOV  rb8, 0x03
ADD  rb7, rb8      # rb7 = 0x08

# CMP sets flags but does not modify registers
MOV  rw9, 42
MOV  rw10, 42
CMP  rw9, rw10     # Z=true (equal), C=false, N=false

HALT
