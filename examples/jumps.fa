# jumps.fa
#
# Demonstrates: global and local labels, JNZ loop, CALL/RET, SP read.
#
# Computes sum_down(3) = 3 + 2 + 1 = 6 via a subroutine.
# Result ends up in rw0 = 6. rw15 holds the initial stack pointer.
# Run with:
#   just asm-exec '(mem_size: "16mb", rom: "target/examples/jumps.fo", devices: [])'

main:
    MOV rw15, sp        # snapshot SP before any stack activity
    MOV rw0, 3
    CALL sum_down       # r0 = 6 on return
    HALT

# sum_down: sum all integers from rw0 down to 1, result in rw0
# args   : rw0 = starting value (>= 1)
# returns: rw0 = sum
# clobbers: rw1, rw2
sum_down:

    MOV rw1, 0          # rw1 = accumulator
    MOV rw2, 1          # rw2 = constant decrement
.loop:
    ADD rw1, rw0        # rw1 += rw0
    SUB rw0, rw2        # rw0--
    CMP rw0, 0
    JNZ .loop           # repeat while r0 != 0
    MOV rw0, rw1        # move result into rw0 for return
    RET
