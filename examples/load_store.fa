# Memory sections example
#
# Demonstrates .rodata, .data, db/dw, char literals, LOAD and STORE.
# Run with:
#   just asm-exec '(mem_size: "16mb", rom: "target/examples/load_store.fo", devices: [hex_io(port: 0)])'

.rodata
    greeting: db 'H', 'i', 0    # null-terminated string
    table:    dw 42, 0x12345678 # 32-bit constants

.data
    counter: dw 0               # mutable word, starts at zero

.code

main:
    # Read first byte of greeting ('H' = 0x48) and print it
    MOV  rw0, greeting
    LOAD rb1, rw0
    OUT  0, rb1

    # Read the first word from table (42 = 0x0000002A), print low byte
    MOV  rw0, table
    LOAD rw2, rw0
    OUT  0, rb2

    # Write 55 (0x37) into counter, then read it back and print
    MOV  rw0, counter
    MOV  rb3, 55
    STORE rw0, rb3              # byte store: write 0x37 to counter's address
    LOAD  rb4, rw0              # byte load: read it back
    OUT   0, rb4

    HALT
